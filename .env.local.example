# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (free tier LLM — Llama 3.3 70B, get key at console.groq.com)
GROQ_API_KEY=gsk_your-groq-key

# Anthropic (paid tier LLM — Claude Sonnet, only needed for paid scans)
ANTHROPIC_API_KEY=sk-ant-your-key

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
VIGIL_TOKEN_MINT=           # SPL token mint address (set after launch)
SCAN_TREASURY_WALLET=       # Receives scan payments
SCAN_PRICE_SOL=0.0001
SCAN_PRICE_TOKEN=100

# ERC-8004 Agent Identity on Solana (8004-solana SDK)
VIGIL_AGENT_KEYPAIR=               # base58-encoded Ed25519 secret key
VIGIL_AGENT_ASSET_PUBKEY=          # Agent NFT pubkey (after registration)
PINATA_JWT=                        # Pinata free tier JWT for IPFS uploads
SOLANA_8004_CLUSTER=mainnet-beta   # devnet | mainnet-beta

# Anchor Programs (Staking / Challenge / Bounty)
VIGIL_STAKING_PROGRAM_ID=          # base58 program ID
VIGIL_CHALLENGE_PROGRAM_ID=        # base58 program ID
BOUNTY_VAULT_PROGRAM_ID=           # base58 program ID

# Base (L2) — dual-chain support (hidden until NEXT_PUBLIC_BASE_ENABLED=true)
NEXT_PUBLIC_BASE_ENABLED=             # set to "true" to activate Base chain in UI + API
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
BASE_RPC_URL=https://mainnet.base.org
BASE_TREASURY_WALLET=                 # 0x...
BASE_VIGIL_TOKEN_ADDRESS=             # 0x... ERC20
BASE_SCAN_PRICE_ETH=0.0001
BASE_SCAN_PRICE_TOKEN=100
BASE_STAKING_CONTRACT=                # 0x...
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID= # WalletConnect Cloud (free)

# MCP Server (optional — defaults to https://vigil.protocol)
VIGIL_API_URL=https://vigil.protocol
