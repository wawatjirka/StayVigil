# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (free tier LLM — Llama 3.3 70B, get key at console.groq.com)
GROQ_API_KEY=gsk_your-groq-key

# Anthropic (paid tier LLM — Claude Sonnet, only needed for x402 paid scans)
ANTHROPIC_API_KEY=sk-ant-your-key

# x402 Payment Protocol
X402_PAY_TO_ADDRESS=0xYourWalletAddress
X402_FACILITATOR_URL=https://facilitator.x402.org

# ERC-8004 Agent Identity (Phase 3)
VIGIL_AGENT_PRIVATE_KEY=0xYourPrivateKey
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ERC8004_IDENTITY_REGISTRY=0xContractAddress
ERC8004_REPUTATION_REGISTRY=0xContractAddress
ERC8004_VALIDATION_REGISTRY=0xContractAddress

# Smart Contract Deployment
DEPLOYER_PRIVATE_KEY=0xYourDeployerPrivateKey

# MCP Server (optional — defaults to https://vigil.protocol)
VIGIL_API_URL=https://vigil.protocol
