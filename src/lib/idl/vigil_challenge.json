{
  "version": "0.1.0",
  "name": "vigil_challenge",
  "instructions": [
    {
      "name": "initialize",
      "accounts": [
        { "name": "config", "isMut": true, "isSigner": false },
        { "name": "stakingProgram", "isMut": false, "isSigner": false },
        { "name": "authority", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "createChallenge",
      "accounts": [
        { "name": "config", "isMut": true, "isSigner": false },
        { "name": "challenge", "isMut": true, "isSigner": false },
        { "name": "auditorStakeInfo", "isMut": false, "isSigner": false },
        { "name": "challenger", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "skillId", "type": "string" },
        { "name": "proofHash", "type": { "array": ["u8", 32] } }
      ]
    },
    {
      "name": "respond",
      "accounts": [
        { "name": "challenge", "isMut": true, "isSigner": false },
        { "name": "auditor", "isMut": false, "isSigner": true }
      ],
      "args": [
        { "name": "counterProofHash", "type": { "array": ["u8", 32] } }
      ]
    },
    {
      "name": "resolve",
      "accounts": [
        { "name": "config", "isMut": false, "isSigner": false },
        { "name": "challenge", "isMut": true, "isSigner": false },
        { "name": "authority", "isMut": false, "isSigner": true }
      ],
      "args": [
        { "name": "shouldSlash", "type": "bool" },
        { "name": "slashAmount", "type": "u64" }
      ]
    }
  ],
  "accounts": [
    {
      "name": "ChallengeConfig",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "type": "publicKey" },
          { "name": "stakingProgram", "type": "publicKey" },
          { "name": "challengeCount", "type": "u64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "Challenge",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "challengeId", "type": "u64" },
          { "name": "challenger", "type": "publicKey" },
          { "name": "auditor", "type": "publicKey" },
          { "name": "skillId", "type": "string" },
          { "name": "proofHash", "type": { "array": ["u8", 32] } },
          { "name": "counterProofHash", "type": { "array": ["u8", 32] } },
          { "name": "createdAt", "type": "i64" },
          { "name": "respondedAt", "type": "i64" },
          { "name": "status", "type": { "defined": "ChallengeStatus" } },
          { "name": "slashAmount", "type": "u64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "ChallengeStatus",
      "type": {
        "kind": "enum",
        "variants": [
          { "name": "Open" },
          { "name": "Responded" },
          { "name": "Slashed" },
          { "name": "Dismissed" }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "AuditorNotStaked", "msg": "Auditor does not have an active stake" },
    { "code": 6001, "name": "ChallengeNotOpen", "msg": "Challenge is not in an open state" },
    { "code": 6002, "name": "DisputeWindowClosed", "msg": "Dispute window has closed (48 hours)" },
    { "code": 6003, "name": "UnauthorizedAuditor", "msg": "Only the challenged auditor can respond" }
  ]
}
