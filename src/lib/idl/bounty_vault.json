{
  "version": "0.1.0",
  "name": "bounty_vault",
  "instructions": [
    {
      "name": "initialize",
      "accounts": [
        { "name": "config", "isMut": true, "isSigner": false },
        { "name": "vigilTokenMint", "isMut": false, "isSigner": false },
        { "name": "authority", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "deposit",
      "accounts": [
        { "name": "config", "isMut": false, "isSigner": false },
        { "name": "depositor", "isMut": true, "isSigner": true },
        { "name": "depositorTokenAccount", "isMut": true, "isSigner": false },
        { "name": "vaultTokenAccount", "isMut": true, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": [{ "name": "amount", "type": "u64" }]
    },
    {
      "name": "createReward",
      "accounts": [
        { "name": "config", "isMut": true, "isSigner": false },
        { "name": "reward", "isMut": true, "isSigner": false },
        { "name": "authority", "isMut": true, "isSigner": true },
        { "name": "systemProgram", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "recipient", "type": "publicKey" },
        { "name": "amount", "type": "u64" },
        { "name": "challengeId", "type": "u64" }
      ]
    },
    {
      "name": "claim",
      "accounts": [
        { "name": "config", "isMut": false, "isSigner": false },
        { "name": "reward", "isMut": true, "isSigner": false },
        { "name": "recipient", "isMut": false, "isSigner": true },
        { "name": "recipientTokenAccount", "isMut": true, "isSigner": false },
        { "name": "vaultTokenAccount", "isMut": true, "isSigner": false },
        { "name": "vaultAuthority", "isMut": false, "isSigner": false },
        { "name": "tokenProgram", "isMut": false, "isSigner": false }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "VaultConfig",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "type": "publicKey" },
          { "name": "vigilTokenMint", "type": "publicKey" },
          { "name": "rewardCount", "type": "u64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    },
    {
      "name": "BountyReward",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "rewardId", "type": "u64" },
          { "name": "recipient", "type": "publicKey" },
          { "name": "amount", "type": "u64" },
          { "name": "claimed", "type": "bool" },
          { "name": "challengeId", "type": "u64" },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "errors": [
    { "code": 6000, "name": "ZeroAmount", "msg": "Amount must be greater than zero" },
    { "code": 6001, "name": "AlreadyClaimed", "msg": "Reward has already been claimed" },
    { "code": 6002, "name": "UnauthorizedRecipient", "msg": "Only the designated recipient can claim" }
  ]
}
